# Obligatorio para Vercel Blob
BLOB_READ_WRITE_TOKEN=

# Obligatorio para Resend
RESEND_API_KEY=

# Remitente visible en el mail (para Gmail conviene que coincida con SMTP_USER)
MAIL_FROM=Alerta Vencimientos <tu-cuenta@gmail.com>

# Opcional: SMTP (si completas estos, se usa SMTP en vez de Resend)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=

# Seguridad para el cron manual/opcional
CRON_SECRET=poneme-un-secreto-largo
